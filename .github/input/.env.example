# Copia este archivo como .env y rellena los valores reales.
# NUNCA commitees el archivo .env — está en .gitignore.

# Asset ID del flujo en Power Automate
# (lo ves en la URL al editar el flujo: /flows/<FLOW_ID>/edit)
PA_FLOW_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Ruta al ZIP exportado desde Power Automate (opcional, por defecto WorkflowDORA_original.zip)
# PA_ORIG_ZIP=.github/input/WorkflowDORA_original.zip

# Group ID del equipo Teams del SOC
# (Settings del equipo → enlace del equipo → groupId=...)
TEAMS_GROUP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Channel ID del canal Teams del SOC
# (enlace del canal → channel=...)
TEAMS_CHANNEL_ID=19:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@thread.tacv2
