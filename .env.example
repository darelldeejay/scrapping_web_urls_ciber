# .env.example - Configuración de cliente (NO commitear .env real)
# Copiar a .env y rellenar con datos del cliente

# Información del cliente
CLIENT_NAME="BANCO PICHINCHA"
CLIENT_CODE="PICHINCHA"
CLIENT_FULL_NAME="Banco Pichincha - Monitoreo DORA ICT"

# Email
EMAIL_SUBJECT_PREFIX="[{CLIENT_NAME} - DORA]"
EMAIL_CONFIDENTIAL_FOOTER="Información exclusiva para uso interno {CLIENT_NAME}"

# Contacto para reportes
CONTACT_PERSON="Equipo de Seguridad"
CONTACT_DEPARTMENT="Seguridad de Información"

# URLs y referencias
CLIENT_PORTAL_URL=""
CLIENT_SUPPORT_EMAIL=""

# Configuración de notificaciones
NOTIFY_TO_TELEGRAM=true
NOTIFY_TO_TEAMS=true
