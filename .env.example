# .env.example - Configuración de cliente (NO commitear .env real)
# Copiar a .env y rellenar con datos del cliente

# ⚠️ IMPORTANTE: Este archivo es UN EJEMPLO genérico
# Reemplaza todos los valores con datos de tu cliente
# El archivo .env real NUNCA se commitea a GitHub

# Información del cliente
CLIENT_NAME="<NOMBRE_CLIENTE>"
CLIENT_CODE="<CÓDIGO_CLIENTE>"
CLIENT_FULL_NAME="<NOMBRE_CLIENTE> - Monitoreo DORA ICT"

# Email
EMAIL_SUBJECT_PREFIX="[<NOMBRE_CLIENTE> - DORA]"
EMAIL_CONFIDENTIAL_FOOTER="Información exclusiva para uso interno <NOMBRE_CLIENTE>"

# Contacto para reportes
CONTACT_PERSON="<NOMBRE_RESPONSABLE>"
CONTACT_DEPARTMENT="<DEPARTAMENTO>"

# URLs y referencias (opcional)
CLIENT_PORTAL_URL="https://security.<cliente>.com"
CLIENT_SUPPORT_EMAIL="security@<cliente>.com"

# Configuración de notificaciones
NOTIFY_TO_TELEGRAM=true
NOTIFY_TO_TEAMS=true

# Email SMTP (para build_digest.py — opcional)
# Gmail: genera una Contraseña de App en Cuenta > Seguridad > Contraseñas de aplicación
SMTP_USER="monitor@gmail.com"
SMTP_PASSWORD="<contraseña-de-aplicación>"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
EMAIL_TO="destinatario@empresa.com"
# EMAIL_FROM="Monitor DORA <monitor@gmail.com>"  # Opcional

# ─────────────────────────────────────────────────
# Firma corporativa del remitente SOC
# Todos estos campos son opcionales: si no se definen,
# la firma queda vacía sin romper el email.
# ─────────────────────────────────────────────────
FIRMA_NOMBRE="Nombre Apellido"
FIRMA_CARGO="Cargo / Rol"
FIRMA_EMAIL="nombre@empresa.com"
FIRMA_WEB="www.empresa.com"
FIRMA_TEL1="+34 900 000 001"
# FIRMA_TEL2="+34 900 000 002"   # Segunda línea de teléfono (opcional)
FIRMA_MOV="+34 600 000 000"
# FIRMA_PGP="0xXXXXXXXX"        # PGP Key ID (opcional)

# URLs de imágenes corporativas (deben ser públicamente accesibles desde internet)
# Déjalas vacías si no tienes las URLs; la firma se mostrará solo con texto.
FIRMA_LOGO_URL="https://www.empresa.com/img/logo.png"
FIRMA_LOGOS_URL="https://www.empresa.com/img/certificaciones.png"
FIRMA_ALLURITY_URL="https://www.empresa.com/img/allurity.png"
