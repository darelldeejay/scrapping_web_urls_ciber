# .env.example - Configuración de cliente (NO commitear .env real)
# Copiar a .env y rellenar con datos del cliente

# ⚠️ IMPORTANTE: Este archivo es UN EJEMPLO genérico
# Reemplaza todos los valores con datos de tu cliente
# El archivo .env real NUNCA se commitea a GitHub

# Información del cliente
CLIENT_NAME="<NOMBRE_CLIENTE>"
CLIENT_CODE="<CÓDIGO_CLIENTE>"
CLIENT_FULL_NAME="<NOMBRE_CLIENTE> - Monitoreo DORA ICT"

# Email
EMAIL_SUBJECT_PREFIX="[<NOMBRE_CLIENTE> - DORA]"
EMAIL_CONFIDENTIAL_FOOTER="Información exclusiva para uso interno <NOMBRE_CLIENTE>"

# Contacto para reportes
CONTACT_PERSON="<NOMBRE_RESPONSABLE>"
CONTACT_DEPARTMENT="<DEPARTAMENTO>"

# URLs y referencias (opcional)
CLIENT_PORTAL_URL="https://security.<cliente>.com"
CLIENT_SUPPORT_EMAIL="security@<cliente>.com"

# Configuración de notificaciones
NOTIFY_TO_TELEGRAM=true
NOTIFY_TO_TEAMS=true
